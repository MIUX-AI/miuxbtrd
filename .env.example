# ============================================================
# MIUX AI TRADING BOT v4.0 — Konfigurasi
# ============================================================

# --- PORT & HOST ---
PORT=3000
HOST=0.0.0.0

# --- TRADING MODE ---
# paper | analysis | safe | live_testnet | live_mainnet
TRADING_MODE=paper

# --- MODAL ---
INITIAL_CAPITAL=10000

# --- DASHBOARD / SESSION ---
# WAJIB diubah sebelum dipakai di jaringan nyata
DASHBOARD_PASSWORD=change_this_dashboard_password
# Kosongkan bila UI dibuka dari URL yang sama dengan server.
# Jika frontend dibuka dari origin lain, isi exact origin dan bisa dipisahkan koma.
# Contoh: http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
DASHBOARD_ORIGIN=
SESSION_SECRET=change_this_session_secret

# --- OUTBOUND HTTP LIMITER ---
# Batasi request eksternal paralel untuk menghindari burst socket di host yang sensitif.
HTTP_MAX_CONCURRENT=6

# --- AI SERVER PRIMARY (lokal / private) ---
AI_PRIMARY_URL=http://127.0.0.1:3573/v1/chat/completions
AI_PRIMARY_KEY=
AI_PRIMARY_MODEL=qwen2.5-3b-instruct-q4
AI_TIMEOUT_MS=35000
AI_MIN_RULE_SCORE=0.68

# --- AI FALLBACK PROVIDERS (isi minimal satu bila diperlukan) ---
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- BINANCE DEMO (live_testnet) ---
BINANCE_DEMO_SPOT_API_KEY=
BINANCE_DEMO_SPOT_API_SECRET=
BINANCE_DEMO_UM_API_KEY=
BINANCE_DEMO_UM_API_SECRET=

# --- BINANCE MAINNET (live_mainnet) ---
BINANCE_MAINNET_SPOT_API_KEY=
BINANCE_MAINNET_SPOT_API_SECRET=
BINANCE_MAINNET_UM_API_KEY=
BINANCE_MAINNET_UM_API_SECRET=

# --- PORTFOLIO TARGETS ---
PORTFOLIO_SPOT_TARGET_PCT=0.90
PORTFOLIO_BTC_WITHIN_SPOT_PCT=0.70
PORTFOLIO_ALT_WITHIN_SPOT_PCT=0.30
PORTFOLIO_UM_TARGET_PCT=0.10

# --- SYMBOLS (pisahkan dengan koma) ---
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,NEARUSDT,DOTUSDT,INJUSDT,SUIUSDT,UNIUSDT,AAVEUSDT,RENDERUSDT,FETUSDT,SEIUSDT,ATOMUSDT,LTCUSDT,WLDUSDT
